#!/usr/bin/expect -f
set timeout 120
log_user 1
spawn ssh -o StrictHostKeyChecking=no -o ServerAliveInterval=10 pi@192.168.100.131 {cat /home/pi/bot2/api/health_api.py; echo '===S1==='; grep -n 'adsb_lol' /home/pi/bot2/api/adsb_api.py /home/pi/bot2/api_server.py; echo '===S2==='; grep -rn 'export\|passes_by_date\|passes_by_satellite' /home/pi/bot2/api_server.py; echo '===S3==='; grep -n 'def \|async def ' /home/pi/bot2/api/openwebrx_api.py; echo '===S4==='; grep -n 'audio.wav\|audio_wav\|audio/pcm\|serve_audio' /home/pi/bot2/api/openwebrx_api.py /home/pi/bot2/api/openwebrx_service.py /home/pi/bot2/api_server.py; echo '===S5==='; sed -n '/def satdump_list_passes/,/^async def/p' /home/pi/bot2/api/satdump_api.py | head -50; echo '===DONE==='}
expect "password:"
send "pobgu9-jabdoP-ruczaq\r"
expect -timeout 90 eof
