# Now SSH and run it
spawn ssh -o StrictHostKeyChecking=no pi@192.168.100.131
expect "password:"
send "pobgu9-jabdoP-ruczaq\r"
expect "\\$"
send "bash /tmp/test_analytics.sh\r"
expect "=== DONE ==="
expect "\\$"
send "exit\r"
