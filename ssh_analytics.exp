# SCP test script first
spawn scp -o StrictHostKeyChecking=no "/Users/eliel/Library/Mobile Documents/com~apple~CloudDocs/apps criados/botapp/MeuLabApp/server_updates/test_analytics.sh" pi@192.168.100.131:/tmp/test_analytics.sh
expect "password:"
